ed_at:(new Date).toISOString()},{id:"e1",title:"食堂养生搭配公式",category:"diet",tags:["饮食","食堂","搭配"],content:"【早餐公式】蛋白质+碳水+维生素\n→ 豆浆/粥 + 鸡蛋 + 小菜/水果\n\n【午餐公式】主食+蛋白质+蔬菜\n→ 米饭 + 鸡腿/鱼 + 两份蔬菜\n\n【晚餐公式】清淡为主\n→ 粥/面 + 蔬菜 + 豆制品",duration:"日常",difficulty:"easy",target_constitutions:["所有体质"],view_count:6789,like_count:567,created_at:(new Date).toISOString()},{id:"e2",title:"外卖健康点单攻略",category:"diet",tags:["外卖","点单","健康"],content:"【推荐选择】\n✓ 清蒸、白灼、凉拌、清炒\n✓ 炖汤、粥品、蒸蛋\n✓ 粗粮饭、杂粮馒头\n\n【避雷指南】\n✗ 干锅、爆炒、水煮鱼（重油）\n✗ 麻辣烫（高盐）\n✗ 炸鸡、薯条（油炸）\n\n【万能备注】少油少盐，不要辣",duration:"日常",difficulty:"easy",target_constitutions:["所有体质"],view_count:8765,like_count:698,created_at:(new Date).toISOString()},{id:"e3",title:"低成本养生水做法",category:"diet",tags:["补水","养生水","低成本"],content:"【柠檬蜂蜜水】适合早上\n→ 柠檬片2-3片 + 蜂蜜1勺 + 温水\n\n【红枣枸杞茶】适合下午\n→ 红枣3颗 + 枸杞10粒 + 开水\n\n【菊花决明子茶】适合用眼多\n→ 菊花3朵 + 决明子5克 + 开水\n\n【陈皮姜茶】适合空调房\n→ 陈皮1片 + 姜丝少许 + 红糖",duration:"日常",difficulty:"easy",target_constitutions:["所有体质"],view_count:5678,like_count:456,created_at:(new Date).toISOString()},{id:"e4",title:"拒绝节食养胃方案",category:"diet",tags:["养胃","节食","三餐"],content:"【错误做法】\n✗ 不吃早餐（伤胃、低血糖）\n✗ 只吃水果（营养不均衡）\n✗ 过度节食（代谢下降）\n\n【正确做法】\n✓ 三餐定时，七八分饱\n✓ 细嚼慢咽，每口20次\n✓ 少吃辛辣生冷，多喝热粥\n✓ 宿舍备点苏打饼干",duration:"日常",difficulty:"easy",target_constitutions:["气虚质","阳虚质","所有体质"],view_count:4567,like_count:378,created_at:(new Date).toISOString()},{id:"e5",title:"熬夜后修复饮食",category:"diet",tags:["熬夜","修复","饮食"],content:"【熬夜后早餐】\n→ 鸡蛋 + 牛奶 + 水果（补充蛋白质和维生素）\n\n【熬夜后加餐】\n→ 坚果一小把（补脑）\n→ 猕猴桃/橙子（补维C）\n\n【禁忌】\n✗ 不要空腹喝咖啡\n✗ 不要吃泡面/烧烤\n✗ 不要大量吃甜食",duration:"日常",difficulty:"easy",target_constitutions:["所有体质"],view_count:3456,like_count:289,created_at:(new Date).toISOString()},{id:"s1",title:"熬夜补救黄金法则",category:"schedule",tags:["熬夜","补救","修复"],content:'【当晚补救】\n1. 尽量在23:30前入睡\n2. 睡前喝一杯温牛奶\n3. 设好闹钟，保证6小时睡眠\n\n【第二天修复】\n1. 中午小憩20分钟（不超过30分钟）\n2. 下午3点后不喝咖啡\n3. 晚餐后散步30分钟\n\n【长期改善】\n→ 设定"手机就寝时间"（如23:00）',duration:"全天",difficulty:"medium",target_constitutions:["阴虚质","气虚质","所有体质"],view_count:9876,like_count:876,created_at:(new Date).toISOString()},{id:"s2",title:"碎片化高效休息法",category:"schedule",tags:["碎片化","休息","效率"],content:"【课间5分钟】\n→ 站起来伸懒腰 + 远眺窗外\n\n【午休20分钟】\n→ 闭眼深呼吸 + 趴桌小憩\n\n【睡前10分钟】\n→ 泡脚 + 简单拉伸\n\n【原理】\n碎片化休息比连续休息更高效，\n每90分钟需要短暂休息一次",duration:"5-20分钟",difficulty:"easy",target_constitutions:["所有体质"],view_count:6543,like_count:543,created_at:(new Date).toISOString()},{id:"s3",title:"478呼吸法入睡法",category:"schedule",tags:["睡眠","呼吸","失眠"],content:"【步骤】\n1. 用鼻子吸气4秒\n2. 屏住呼吸7秒\n3. 用嘴巴呼气8秒\n4. 重复3-4次\n\n【适用场景】\n✓ 睡前焦虑\n✓ 考试前紧张\n✓ 情绪低落时\n\n【效果】\n激活副交感神经，快速放松",duration:"2分钟",difficulty:"easy",target_constitutions:["气郁质","阴虚质","所有体质"],view_count:12345,like_count:1023,created_at:(new Date).toISOString()},{id:"s4",title:"作息紊乱7天调整计划",category:"schedule",tags:["作息","调整","紊乱"],content:"【第1-2天】\n→ 记录当前作息时间\n→ 设定目标：23:00睡，7:00起\n\n【第3-4天】\n→ 每天提前30分钟入睡\n→ 早晨闹钟响后立刻起床\n\n【第5-7天】\n→ 达到目标作息\n→ 白天多晒太阳，晚上少玩手机\n\n【tip】\n睡不着可以听白噪音或轻音乐",duration:"7天",difficulty:"medium",target_constitutions:["所有体质"],view_count:4567,like_count:389,created_at:(new Date).toISOString()},{id:"s5",title:"周末补觉正确方式",category:"schedule",tags:["补觉","周末","睡眠"],content:"【错误做法】\n✗ 周六睡到中午12点\n✗ 周末熬夜到凌晨2-3点\n\n【正确做法】\n✓ 周末起床时间不晚于工作日1小时\n✓ 午睡控制在30分钟内\n✓ 晚上11点前入睡\n\n【原因】\n作息波动过大会打乱生物钟，\n反而更累",duration:"周末",difficulty:"easy",target_constitutions:["气虚质","阴虚质","所有体质"],view_count:5678,like_count:467,created_at:(new Date).toISOString()},{id:"se1",title:"换季防感冒必备指南",category:"seasonal",tags:["换季","感冒","预防"],content:"【预防措施】\n1. 及时增减衣物（洋葱式穿衣）\n2. 每天开窗通风2次，每次15分钟\n3. 多喝热水，少吃辛辣\n4. 适当补充维生素C\n\n【早期症状处理】\n→ 喝姜糖水 + 早点睡觉\n→ 用热水泡脚\n\n【禁忌】\n✗ 不要捂汗（容易脱水）\n✗ 不要剧烈运动",duration:"换季",difficulty:"easy",target_constitutions:["所有体质"],view_count:8765,like_count:678,created_at:(new Date).toISOString()},{id:"se2",title:"夏季祛湿满分方案",category:"seasonal",tags:["夏季","祛湿","湿热"],content:"【饮食祛湿】\n✓ 薏米红豆粥（炒薏米更温和）\n✓ 冬瓜汤、苦瓜、绿豆汤\n✓ 陈皮泡水\n\n【生活祛湿】\n✓ 适度运动出汗（不要久吹空调）\n✓ 洗热水澡、泡脚\n✓ 穿透气衣物\n\n【避雷】\n✗ 淋雨涉水\n✗ 吃太多甜食和冷饮",duration:"夏季",difficulty:"easy",target_constitutions:["湿热质","痰湿质","所有体质"],view_count:6789,like_count:567,created_at:(new Date).toISOString()},{id:"se3",title:"秋冬润燥滋阴指南",category:"seasonal",tags:["秋冬","润燥","滋阴"],content:"【饮食润燥】\n✓ 梨、百合、银耳、莲子\n✓ 蜂蜜水（温水冲泡）\n✓ 芝麻、核桃、杏仁\n\n【生活保湿】\n✓ 室内使用加湿器\n✓ 多喝水，少量多次\n✓ 涂抹身体乳、护手霜\n\n【禁忌】\n✗ 辛辣食物（加重干燥）\n✗ 熬夜（伤阴）",duration:"秋冬",difficulty:"easy",target_constitutions:["阴虚质","血瘀质","所有体质"],view_count:5678,like_count:456,created_at:(new Date).toISOString()},{id:"se4",title:"考前7天养生冲刺计划",category:"seasonal",tags:["考前","备考","考试周"],content:"【考前7天】\n→ 调整作息，早睡早起\n→ 每天散步20分钟放松\n→ 饮食清淡，多吃蛋白质\n\n【考前3天】\n→ 减少新知识学习\n→ 复习重点笔记\n→ 早睡，保证7-8小时睡眠\n\n【考试当天】\n→ 早餐要吃好\n→ 提前到考场，深呼吸放松\n→ 带一瓶水和巧克力",duration:"考试周",difficulty:"easy",target_constitutions:["所有体质"],view_count:15678,like_count:1234,created_at:(new Date).toISOString()},{id:"se5",title:"夏季防暑降温妙招",category:"seasonal",tags:["夏季","防暑","降温"],content:"【饮食防暑】\n✓ 绿豆汤、酸梅汤、西瓜\n✓ 喝温开水，少喝冰水\n✓ 多吃蔬菜水果\n\n【生活防暑】\n✓ 避免10-16点户外活动\n✓ 穿透气浅色衣物\n✓ 午休30分钟补充精力\n\n【禁忌】\n✗ 运动后立刻喝冰饮\n✗ 长时间直吹空调",duration:"夏季",difficulty:"easy",target_constitutions:["所有体质"],view_count:4567,like_count:345,created_at:(new Date).toISOString()}];const op=function(){var e,t,r,i,o=ep((0,n.useState)(ip),2),a=o[0],s=o[1],l=ep((0,n.useState)(null),2),c=l[0],u=l[1],d=ep((0,n.useState)(""),2),h=d[0],f=d[1],p=ep((0,n.useState)(new Set),2),m=p[0],g=p[1],y=ep((0,n.useState)("气虚质"),1)[0],v=ep((0,n.useState)(null),2),b=v[0],w=v[1],x=ep((0,n.useState)({}),2),k=x[0],j=x[1],S=ep((0,n.useState)(new Set),2),_=S[0],O=S[1];(0,n.useEffect)(function(){var e=localStorage.getItem("wellness_favorites"),t=localStorage.getItem("wellness_likes");e&&g(new Set(JSON.parse(e))),t&&O(new Set(JSON.parse(t)))},[]);var E=function(e){g(function(t){var n=new Set(t);return n.has(e)?n.delete(e):n.add(e),localStorage.setItem("wellness_favorites",JSON.stringify(Zf(n))),n})},P=function(e){O(function(t){var n,r,i=new Set(t),o=a.find(function(t){return t.id===e}),s=null!==(n=null!==(r=k[e])&&void 0!==r?r:null==o?void 0:o.like_count)&&void 0!==n?n:0;retu